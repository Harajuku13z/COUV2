APP_NAME="Artisan SEO Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://admin.lj.osmoseconsulting.fr
APP_DOMAIN=lj.osmoseconsulting.fr
APP_ADMIN_DOMAIN=admin.lj.osmoseconsulting.fr

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=redis

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artisan_seo_central
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

TENANCY_DATABASE_TEMPLATE_CONNECTION=mysql
TENANCY_DATABASE_PREFIX=tenant_
TENANCY_DATABASE_SUFFIX=
TENANCY_DB_HOST=127.0.0.1
TENANCY_DB_PORT=3306
TENANCY_DB_USERNAME=root
TENANCY_DB_PASSWORD=
TENANCY_DB_CHARSET=utf8mb4
TENANCY_DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=artisan_seo_platform

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_HORIZON_DB=3
REDIS_PREFIX=artisan_seo_platform_
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE_RETRY_AFTER=180

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT=120

SERPAPI_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search
SERPAPI_TIMEOUT=60

OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
OPENWEATHER_TIMEOUT=30

HORIZON_NAME=artisan-seo-platform
HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_PREFIX=artisan_seo_platform_horizon:

TENANCY_CENTRAL_DOMAINS=127.0.0.1,localhost,lj.osmoseconsulting.fr,www.lj.osmoseconsulting.fr,admin.lj.osmoseconsulting.fr

VITE_APP_NAME="${APP_NAME}"
