APP_NAME="Artisan SEO Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://lj.osmoseconsulting.fr
APP_DOMAIN=lj.osmoseconsulting.fr
APP_ADMIN_DOMAIN=admin.lj.osmoseconsulting.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=info

DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artisan_seo_central
DB_USERNAME=artisan_user
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

TENANCY_DATABASE_TEMPLATE_CONNECTION=mysql
TENANCY_DATABASE_PREFIX=tenant_
TENANCY_DATABASE_SUFFIX=
TENANCY_DB_HOST=127.0.0.1
TENANCY_DB_PORT=3306
TENANCY_DB_USERNAME=artisan_user
TENANCY_DB_PASSWORD=change-me
TENANCY_DB_CHARSET=utf8mb4
TENANCY_DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=artisan_seo_platform

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_HORIZON_DB=3
REDIS_PREFIX=artisan_seo_platform_

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@lj.osmoseconsulting.fr
MAIL_PASSWORD=change-me
MAIL_FROM_ADDRESS=no-reply@lj.osmoseconsulting.fr
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT=120

SERPAPI_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search
SERPAPI_TIMEOUT=60

OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
OPENWEATHER_TIMEOUT=30

TENANCY_CENTRAL_DOMAINS=127.0.0.1,localhost,lj.osmoseconsulting.fr,www.lj.osmoseconsulting.fr,admin.lj.osmoseconsulting.fr

VITE_APP_NAME="${APP_NAME}"
